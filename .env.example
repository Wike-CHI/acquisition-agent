# acquisition-agent 环境变量配置
# 复制为 .env 并填写实际值
# cp .env.example .env
#
# 配置完成后运行: bash workspace/setup-user.sh

# === 业务员信息（每个业务员不同）===
OWNER_NAME=你的名字
OWNER_DISPLAY_NAME=你的英文名 / Sale Manager
COMPANY_NAME=HOLO Industrial Equipment Mfg Co., Ltd
COMPANY_FULL_NAME=温州红龙工业设备制造有限公司（HOLO Industrial Equipment Mfg Co., Ltd）
BRAND_NAME=HOLO
OWNER_EMAIL=your@email.com
OWNER_PHONE=+86 xxx xxxx xxxx
GITHUB_USER=your-github-user
FACTORY_LOCATION=中国温州
TIMEZONE=中国（UTC+8）

# === 业务配置 ===
COMPETITOR_NAME=Beltwin
PIPELINE_DATA_PATH=C:/Users/YourName/WorkBuddy/

# === 邮件 SMTP（可选，也可在代码中配置） ===
# HOLO_SMTP_USER=your@email.com
# HOLO_SMTP_PASS=your-auth-code
