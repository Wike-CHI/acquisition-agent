venv/
*.egg-info/
dist/
build/
*.egg

# --- WorkBuddy 内部 ---
.workbuddy/
.learnings/
.release/

# --- 打包文件 ---
releases/
*.zip
*.tar.gz

# --- 系统文件 ---
.DS_Store
Thumbs.db
desktop.ini

# --- 插件/扩展（不属于本项目）---
plugins/
extensions/
