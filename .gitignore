.idea/
.vscode/
*.swp
*.swo
*~

# --- 构建产物 / 缓存 ---
binaries/
coverage/
test-output/
__pycache__/
*.pyc
*.pyo
*.tmp
*.temp
*.bak

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

